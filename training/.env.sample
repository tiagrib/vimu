# VIMU training configuration
# Copy this file to .env and adjust paths for your setup

# Directory containing video files
VIDEO_DIR=./adelino_v1/

# Output directory for annotations, frames, and masks
OUTPUT_DIR=./seg_data/

# Directory for trained models (family/variant structure)
# MODELS_DIR=./models/
# Falls back to <repo_root>/models/ if not set

# Directory for pose data collection (Phase 3)
POSE_DATA_DIR=./pose_data/

# WebSocket URL of the robot controller (for collect_pose.py)
CONTROLLER_WS=ws://localhost:8765

# Frame extraction rate (every Nth frame)
EVERY_N=2

# SAM2 model: tiny, small, base_plus, large
MODEL=large

# Device: cuda or cpu
DEVICE=cuda
